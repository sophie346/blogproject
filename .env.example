# --- Active client / tenant ---
# Selects which client definition loads from src/clients/<name>.ts
# (brand, theme, footer links, hero copy). Default: oneauto
# Available: oneauto | nexus
CLIENT_NAME=oneauto

# OneAuto BFF (WebsiteRoutes/blogs.js) — local default port 3005
# Start BFF first:  cd ../oneauto && npm run dev
# Endpoints: GET /prod/blogs , GET /prod/blogs/:slug
# Only published/scheduled-due posts are returned (drafts are hidden).
ONEAUTO_API_BASE=http://127.0.0.1:3005

# Org id — sent as the `clientname` request header
ONEAUTO_CLIENTNAME=oneauto

# Website label — query param + `label` header
WEBSITE_LABEL=oneauto

# Optional storefront Bearer token (guest /prod access works without it)
# ONEAUTO_AUTH_TOKEN=

# --- SEO / public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default Open Graph / Twitter image (absolute https URL)
# NEXT_PUBLIC_OG_IMAGE=https://example.com/og-default.jpg

# Organization logo for JSON-LD
# NEXT_PUBLIC_SITE_LOGO=https://example.com/logo.png

# Social profiles used in Organization schema sameAs + article:publisher
# NEXT_PUBLIC_FACEBOOK_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_TIKTOK_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
